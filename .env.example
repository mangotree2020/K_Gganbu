# 클라이언트(앱 번들에 노출됨) — EXPO_PUBLIC_ 접두사만 여기에 둘 것.
# 비밀키(ANTHROPIC/GOOGLE_TRANSLATION/NAVER_SECRET/TOUR_API 등)는 절대 EXPO_PUBLIC_ 로 두지 말고
# Supabase Edge Function 시크릿(supabase secrets set)으로만 관리한다.

EXPO_PUBLIC_API_URL=https://your-api.com
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Naver Maps — 지도 렌더링용 공개 Client ID (SECRET은 서버 시크릿 NAVER_CLIENT_SECRET)
EXPO_PUBLIC_NAVER_MAPS_CLIENT_ID=

# Google Maps — 지도 렌더링용 (앱 제한 키 권장)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase (FCM/Analytics) — 식별자(비밀 아님)
FIREBASE_PROJECT_ID=
FIREBASE_SENDER_ID=

# ── 서버 전용 시크릿 (여기 X — Supabase Edge Function 시크릿으로 설정) ──
# supabase secrets set ANTHROPIC_API_KEY=...           # AI 깐부(gganbu)
# supabase secrets set GOOGLE_TRANSLATION_API_KEY=...  # 번역(translate)
# supabase secrets set TOUR_API_KEY=...                # 장소(places/gganbu)
# supabase secrets set NAVER_CLIENT_ID=... NAVER_CLIENT_SECRET=...  # K-Map(향후 Naver Search/Directions)
