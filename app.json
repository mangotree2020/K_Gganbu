{
  "expo": {
    "name": "K-Gganbu",
    "slug": "travel-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "travel-app",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mangonw.k-kambu",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.mangonw.gganbu",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.ACTIVITY_RECOGNITION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-font",
      "expo-web-browser",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "./plugins/withFirebasePodfile",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "실시간 음성 통역과 AI 깐부 음성 질문을 위해 마이크를 사용합니다.",
          "iosBackgroundMode": true,
          "androidForegroundService": false,
          "androidPermissions": ["android.permission.RECORD_AUDIO"]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "메뉴·간판 사진을 번역하기 위해 사진 접근이 필요합니다.",
          "cameraPermission": "메뉴·간판을 촬영해 번역하기 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "주변 장소와 길찾기를 위해 현재 위치를 사용합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
